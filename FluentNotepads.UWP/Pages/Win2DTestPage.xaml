<Page
    x:Class="FluentNotepads.Pages.Win2DTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FluentNotepads.Pages"
    xmlns:engine="using:FluentNotepads.EditingEngine"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 状态栏 -->
        <StackPanel Grid.Row="0" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" 
                    Padding="16,8" Spacing="8">
            <TextBlock Text="Win2D 编辑器测试页面" 
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="StatusText" 
                       Text="正在初始化..." 
                       Foreground="{ThemeResource SystemColorHighlightTextBrush}"/>
        </StackPanel>

        <!-- Win2D 编辑器区域 -->
        <Border Grid.Row="1" BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}" 
                BorderThickness="1" Margin="16">
            <engine:Win2DTextEditor x:Name="Editor" 
                                   Loaded="Editor_Loaded"/>
        </Border>
    </Grid>
</Page>
